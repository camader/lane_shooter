; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited with a text editor if you know what you're doing.

[application]

config/name="Lane Shooter"
config/features=PackedStringArray("4.6")
run/main_scene="res://scenes/main.tscn"

[autoload]

GameData="*res://scripts/game_data.gd"
SaveManager="*res://scripts/save_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[layer_names]

3d_physics/layer_1="player"
3d_physics/layer_2="bullets"
3d_physics/layer_3="enemies"

[rendering]

renderer/rendering_method="forward_plus"
